# GoldRush Studio — host config. Copy to .env (gitignored) and fill in.
#
# NOTE: There is NO ANTHROPIC_API_KEY here. This platform is Bring-Your-Own-Key:
# each user enters their Anthropic key in the web UI per generation. It is held
# in memory only and never written to disk — so it must NOT be a host setting.

# HTTP port for the API + web UI.
PORT=8080

# Job sandbox image tag (built via docker/Dockerfile.job).
GODOPLAT_JOB_IMAGE=godoplat-job:latest

# Whole-container wall-clock ceiling in ms (default 20 min).
GODOPLAT_JOB_TIMEOUT_MS=1200000

# Agent iteration cap (claude --max-turns).
GODOPLAT_MAX_TURNS=60

# Container resource limits.
GODOPLAT_JOB_MEMORY=4g
GODOPLAT_JOB_CPUS=2
GODOPLAT_JOB_PIDS=512

# Optional asset-generation keys. If set, they ARE written into the game repo's
# .env (the generator reads them there). Leave blank to use procedural assets.
GOOGLE_API_KEY=
XAI_API_KEY=
TRIPO3D_API_KEY=
