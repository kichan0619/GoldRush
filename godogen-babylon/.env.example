# godogen-babylon API keys — copy to `.env` and fill in your own values.
# Every value below is a PLACEHOLDER. Nothing here is a real key.
#
# These are read by shared/skills/godogen/tools/asset_gen.py for AI asset
# generation. The pipeline runs without them (it falls back to procedural
# stand-in assets) — they are only needed when you want generated art.

# Google AI Studio (Gemini) — precise image generation (references, characters).
# Get one at https://aistudio.google.com/
GOOGLE_API_KEY=your-gemini-api-key-here

# xAI (Grok) — fast/cheap images, textures, and video generation.
# Get one at https://console.x.ai/
XAI_API_KEY=your-xai-api-key-here

# Tripo3D — image-to-3D (GLB) model generation.
# Get one at https://platform.tripo3d.ai/
TRIPO3D_API_KEY=your-tripo3d-api-key-here

# --- Optional: Telegram proof push (only used with publish.sh --video_hook) ---
# Install tg-push (https://github.com/htdt/tg-push) and set these to have the
# Stop hook send the final result video to a chat. Leave blank to disable.
TG_BOT_TOKEN=
TG_CHAT_ID=
